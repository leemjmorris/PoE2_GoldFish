<Window x:Class="PoE2Overlay.Features.Memo.MemoOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource OverlayWindowStyle}"
        ShowActivated="False"
        Width="350" Height="400"
        MinWidth="250" MinHeight="200">
    <Border Background="{StaticResource PrimaryBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Opacity="0.92">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource SecondaryBrush}"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="OnTitleBarDrag">
                <Grid>
                    <TextBlock Text="Memo" Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0"
                               FontSize="13" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="&#x2715;" Style="{StaticResource TitleBarButton}"
                                Click="OnCloseClick"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBox Grid.Row="1" x:Name="MemoTextBox"
                     Background="Transparent"
                     Foreground="{StaticResource TextBrush}"
                     CaretBrush="{StaticResource AccentBrush}"
                     BorderThickness="0"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Padding="10"
                     FontSize="13"
                     TextChanged="OnTextChanged"/>

            <Border Grid.Row="2" Background="{StaticResource SecondaryBrush}"
                    CornerRadius="0,0,8,8">
                <Grid>
                    <TextBlock x:Name="StatusText" Text="Ready"
                               Foreground="#88EAEAEA" FontSize="11"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,5,0">
                        <Button Content="Save" Style="{StaticResource TitleBarButton}"
                                Width="50" Click="OnSaveClick"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Thumb Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Width="16" Height="16" Opacity="0"
                   DragDelta="OnResizeDrag" Cursor="SizeNWSE"/>
        </Grid>
    </Border>
</Window>