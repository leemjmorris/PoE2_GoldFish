<core:OverlayBase x:Class="PoE2Overlay.Features.PassiveTree.PassiveTreeOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:PoE2Overlay.Core"
        Style="{StaticResource OverlayWindowStyle}"
        ShowActivated="False"
        Width="900" Height="700"
        MinWidth="400" MinHeight="300">
    <Border Style="{StaticResource OverlayBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- 타이틀바 -->
            <Border Grid.Row="0" Background="{StaticResource SecondaryBrush}"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="OnTitleBarDrag">
                <Grid>
                    <TextBlock Text="Passive Skill Tree"
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0"
                               FontSize="13" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="&#x2715;"
                                Style="{StaticResource TitleBarButton}"
                                Click="OnCloseClick"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- PoB URL / 빌드 코드 입력 -->
            <Border Grid.Row="1" Background="{StaticResource SecondaryBrush}" Padding="8,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="54"/>
                        <ColumnDefinition Width="32"/>
                    </Grid.ColumnDefinitions>

                    <!-- TextBox + placeholder 레이어 -->
                    <Grid Grid.Column="0">
                        <TextBox x:Name="PobInput"
                                 Background="#22FFFFFF"
                                 Foreground="{StaticResource TextBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 CaretBrush="{StaticResource TextBrush}"
                                 SelectionBrush="{StaticResource AccentBrush}"
                                 FontSize="11" Padding="6,4"
                                 VerticalContentAlignment="Center"
                                 TextChanged="OnInputTextChanged"
                                 KeyDown="OnInputKeyDown"/>
                        <TextBlock x:Name="PobHint"
                                   Text="pobb.in URL 또는 PoB2 빌드 코드 붙여넣기..."
                                   Foreground="#55EAEAEA" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <Button Grid.Column="1" Content="Load"
                            Style="{StaticResource TitleBarButton}"
                            Margin="4,0,0,0"
                            Click="OnLoadClick"/>

                    <Button Grid.Column="2" Content="&#x21BA;"
                            Style="{StaticResource TitleBarButton}"
                            ToolTip="할당 노드 초기화"
                            Click="OnClearClick"/>
                </Grid>
            </Border>

            <!-- 트리 렌더링 영역 -->
            <Border Grid.Row="2"
                    x:Name="TreeViewport"
                    ClipToBounds="True"
                    Background="#0D111E"
                    MouseWheel="OnViewportMouseWheel"
                    MouseLeftButtonDown="OnViewportMouseDown"
                    MouseLeftButtonUp="OnViewportMouseUp"
                    MouseMove="OnViewportMouseMove"
                    Cursor="SizeAll">
                <Canvas x:Name="TreeCanvas">
                    <Canvas.RenderTransform>
                        <MatrixTransform x:Name="CanvasTransform"/>
                    </Canvas.RenderTransform>
                </Canvas>
            </Border>

            <!-- 상태바 -->
            <Border Grid.Row="3" Background="{StaticResource SecondaryBrush}"
                    CornerRadius="0,0,8,8">
                <Grid>
                    <TextBlock x:Name="StatusText"
                               Foreground="#88EAEAEA" FontSize="11"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,40,0">
                        <TextBlock x:Name="AllocText"
                                   Foreground="#88EAEAEA" FontSize="11"
                                   Margin="0,0,12,0"/>
                        <TextBlock x:Name="ZoomText"
                                   Foreground="#88EAEAEA" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Thumb Grid.Row="3" HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Width="16" Height="16" Opacity="0"
                   DragDelta="OnResizeDrag" Cursor="SizeNWSE"/>
        </Grid>
    </Border>
</core:OverlayBase>
