<Window x:Class="PoE2Overlay.Features.Screenshot.ScreenshotOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource OverlayWindowStyle}"
        ShowActivated="False"
        Width="400" Height="500"
        MinWidth="300" MinHeight="250">
    <Border Background="{StaticResource PrimaryBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="8" Opacity="0.92">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <!-- 타이틀바 -->
            <Border Grid.Row="0" Background="{StaticResource SecondaryBrush}"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="OnTitleBarDrag">
                <Grid>
                    <TextBlock Text="Screenshots"
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0"
                               FontSize="13" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="&#x2715;"
                                Style="{StaticResource TitleBarButton}"
                                Click="OnCloseClick"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 디렉토리 선택 -->
            <Border Grid.Row="1" Padding="8,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="DirectoryText"
                               Text="Select screenshot folder..."
                               Foreground="#88EAEAEA" FontSize="11"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <Button Grid.Column="1" Content="Browse"
                            Style="{StaticResource TitleBarButton}"
                            Width="60" Click="OnBrowseClick"/>
                </Grid>
            </Border>

            <!-- 썸네일 그리드 -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="ThumbnailList"
                              Padding="8">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="4" Padding="2"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    MouseEnter="OnThumbnailMouseEnter"
                                    MouseLeave="OnThumbnailMouseLeave"
                                    Tag="{Binding FilePath}">
                                <StackPanel>
                                    <Image Source="{Binding Thumbnail}"
                                           Width="150" Height="100"
                                           Stretch="Uniform"/>
                                    <TextBlock Text="{Binding FileName}"
                                               Foreground="#88EAEAEA"
                                               FontSize="9"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="150"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 상태바 + 리사이즈 -->
            <Border Grid.Row="3" Background="{StaticResource SecondaryBrush}"
                    CornerRadius="0,0,8,8">
                <TextBlock x:Name="StatusText" Text="No directory selected"
                           Foreground="#88EAEAEA" FontSize="11"
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
            </Border>

            <Thumb Grid.Row="3" HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Width="16" Height="16" Opacity="0"
                   DragDelta="OnResizeDrag" Cursor="SizeNWSE"/>
        </Grid>
    </Border>
</Window>
