<Window x:Class="PoE2Overlay.Features.Trade.TradeOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource OverlayWindowStyle}"
        ShowActivated="False"
        Width="420" Height="600"
        MinWidth="380" MinHeight="400">
    <Border Background="{StaticResource PrimaryBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="8" Opacity="0.95">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <!-- 타이틀바 -->
            <Border Grid.Row="0" Background="{StaticResource SecondaryBrush}"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="OnTitleBarDrag">
                <Grid>
                    <TextBlock Text="Price Check"
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0"
                               FontSize="13" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="&#x2715;"
                                Style="{StaticResource TitleBarButton}"
                                Click="OnCloseClick"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 아이템 헤더 -->
            <StackPanel Grid.Row="1" Margin="12,8">
                <TextBlock x:Name="ItemNameText"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="15" FontWeight="Bold"/>
                <TextBlock x:Name="ItemBaseText"
                           Foreground="#AAEAEAEA" FontSize="12"/>
                <TextBlock x:Name="ItemLevelText"
                           Foreground="#66EAEAEA" FontSize="11" Margin="0,2,0,0"/>
                <Separator Background="{StaticResource BorderBrush}" Margin="0,6"/>

                <!-- 리그 + 검색 -->
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="League:"
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"
                               FontSize="12"/>
                    <TextBox x:Name="LeagueInput" Grid.Column="1"
                             Style="{StaticResource OverlayTextInput}"
                             Text="Standard"/>
                    <Button Grid.Column="2" Content="Search"
                            Style="{StaticResource TitleBarButton}"
                            Width="60" Margin="8,0,0,0"
                            Click="OnSearchClick"/>
                </Grid>
            </StackPanel>

            <!-- 탭: Filters / Results -->
            <TabControl Grid.Row="2" Style="{StaticResource OverlayTabControl}"
                        Margin="4,0">

                <TabItem Header="Filters" Style="{StaticResource OverlayTabItem}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ModFiltersPanel" Margin="8"/>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Results" Style="{StaticResource OverlayTabItem}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="8,4">
                            <TextBlock x:Name="ResultSummaryText"
                                       Foreground="#AAEAEAEA" FontSize="11"/>
                            <TextBlock x:Name="MedianPriceText"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="14" FontWeight="Bold"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <ListView Grid.Row="1" x:Name="ResultsList"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="{StaticResource TextBrush}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding AccountName}"
                                                   Foreground="#88EAEAEA"
                                                   FontSize="11"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding PriceText}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="12" FontWeight="SemiBold"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- 상태바 -->
            <Border Grid.Row="3" Background="{StaticResource SecondaryBrush}"
                    CornerRadius="0,0,8,8">
                <TextBlock x:Name="StatusText" Text="Ctrl+C on item in PoE2"
                           Foreground="#88EAEAEA" FontSize="11"
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
            </Border>

            <Thumb Grid.Row="3" HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Width="16" Height="16" Opacity="0"
                   DragDelta="OnResizeDrag" Cursor="SizeNWSE"/>
        </Grid>
    </Border>
</Window>
