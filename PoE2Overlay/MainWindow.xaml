<Window x:Class="PoE2Overlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="PoE2 Overlay" Height="0" Width="0"
        WindowStyle="None" ShowInTaskbar="False"
        Visibility="Hidden">
    <Grid>
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="PoE2 Overlay">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Memo (F2)" Click="OnMemoClick"/>
                    <MenuItem Header="Screenshot (F3)" Click="OnScreenshotClick"/>
                    <MenuItem Header="Passive Tree (F4)" Click="OnPassiveTreeClick"/>
                    <MenuItem Header="Settings" Click="OnSettingsClick"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="OnExitClick"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>